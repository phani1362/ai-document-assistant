# Free Google Gemini API key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Free Gemini models (chat + embeddings). Embeddings pinned to 1536 dims to match Upstash index.
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

UPSTASH_VECTOR_REST_URL="your-upstash-url-here"
UPSTASH_VECTOR_REST_TOKEN="your-upstash-token-here"
UPSTASH_REDIS_REST_URL="your-upstash-redis-url-here"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token-here"
